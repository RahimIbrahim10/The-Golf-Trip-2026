  { id: 14, day: 'Saturday', label: 'Morning Match 3', format: '1v1 Net', isTeam: false, sideAPlayer1: 'TBD', sideAPlayer2: '', sideBPlayer1: 'TBD', sideBPlayer2: '', gross: '', net: '', points: '' },
  { id: 15, day: 'Saturday', label: 'Morning Match 4', format: '1v1 Net', isTeam: false, sideAPlayer1: 'TBD', sideAPlayer2: '', sideBPlayer1: 'TBD', sideBPlayer2: '', gross: '', net: '', points: '' },
  { id: 16, day: 'Saturday', label: 'Afternoon Match 1', format: '2v2 Split Format', isTeam: true, sideAPlayer1: 'TBD', sideAPlayer2: 'TBD', sideBPlayer1: 'TBD', sideBPlayer2: 'TBD', gross: '', net: '', points: '' },
  { id: 17, day: 'Saturday', label: 'Afternoon Match 2', format: '2v2 Split Format', isTeam: true, sideAPlayer1: 'TBD', sideAPlayer2: 'TBD', sideBPlayer1: 'TBD', sideBPlayer2: 'TBD', gross: '', net: '', points: '' },
];

function Pill({ children }) {
  return <span className="pill">{children}</span>;
}

function SelectPlayer({ value, onChange, adminMode }) {
  if (!adminMode) return <div className="readonly">{value || '—'}</div>;
  return (
    <select className="field" value={value} onChange={(e) => onChange(e.target.value)}>
      {players.map((p) => <option key={p} value={p}>{p}</option>)}
    </select>
  );
}

function TextField({ value, onChange, placeholder, adminMode }) {
  if (!adminMode) return <div className="readonly">{value || '—'}</div>;
  return <input className="field" value={value} onChange={(e) => onChange(e.target.value)} placeholder={placeholder} />;
}

function MatchCard({ match, adminMode, updateMatch }) {
  return (
    <div className="matchCard">
      <div className="matchHead">
        <div>
          <div className="matchLabel">{match.label}</div>
          <div className="muted">{match.format}</div>
        </div>
        <Pill>Final</Pill>
      </div>

      <div className="grid2">
        <div className="subCard">
          <div className="subTitle">Side A</div>
          {match.fixedTeams ? (
            <div className="readonly strong">Shields</div>
          ) : (
            <div className="stack2">
              <SelectPlayer value={match.sideAPlayer1} onChange={(v) => updateMatch(match.id, 'sideAPlayer1', v)} adminMode={adminMode} />
              {match.isTeam ? <SelectPlayer value={match.sideAPlayer2} onChange={(v) => updateMatch(match.id, 'sideAPlayer2', v)} adminMode={adminMode} /> : null}
            </div>
          )}
        </div>
        <div className="subCard">
          <div className="subTitle">Side B</div>
          {match.fixedTeams ? (
            <div className="readonly strong">Swords</div>
          ) : (
            <div className="stack2">
              <SelectPlayer value={match.sideBPlayer1} onChange={(v) => updateMatch(match.id, 'sideBPlayer1', v)} adminMode={adminMode} />
              {match.isTeam ? <SelectPlayer value={match.sideBPlayer2} onChange={(v) => updateMatch(match.id, 'sideBPlayer2', v)} adminMode={adminMode} /> : null}
            </div>
          )}
        </div>
      </div>

      <div className="grid3">
        <div>
          <div className="subTitle">Final Gross</div>
          <TextField value={match.gross} onChange={(v) => updateMatch(match.id, 'gross', v)} placeholder="e.g. 72 / 74" adminMode={adminMode} />
        </div>
        <div>
          <div className="subTitle">Final Net</div>
          <TextField value={match.net} onChange={(v) => updateMatch(match.id, 'net', v)} placeholder="e.g. 67 / 69" adminMode={adminMode} />
        </div>
        <div>
          <div className="subTitle">Team Points</div>
          <TextField value={match.points} onChange={(v) => updateMatch(match.id, 'points', v)} placeholder="e.g. Shields 1" adminMode={adminMode} />
        </div>
      </div>
    </div>
  );
}

function ScoreControl({ label, value, setValue, adminMode }) {
  return (
    <div className="scoreControl">
      <div className="muted small">{label}</div>
      <div className="scoreRow">
        {adminMode ? <button className="circleBtn" onClick={() => setValue(Math.max(0, value - 1))}>−</button> : null}
        <div className="scoreValue">{value}</div>
        {adminMode ? <button className="circleBtn primary" onClick={() => setValue(value + 1)}>+</button> : null}
      </div>
    </div>
  );
}

function HeatMeter({ shields, swords, streakTeam, streakCount }) {
  const leftPct = Math.min((shields / 17) * 50, 50);
  const rightPct = Math.min((swords / 17) * 50, 50);
  const heaterOn = streakCount >= 3;
  return (
    <div>
      <div className="meterLabels"><span>Shields</span><span className="target">17</span><span>Swords</span></div>
      <div className="meterTrack">
        <div className={`meterFill left ${heaterOn && streakTeam === 'shields' ? 'heater' : ''}`} style={{ width: `${leftPct}%` }} />
        <div className={`meterFill right ${heaterOn && streakTeam === 'swords' ? 'heater' : ''}`} style={{ width: `${rightPct}%` }} />
        <div className="meterCenter" />
        <div className="meterText">17</div>
      </div>
      <div className="heaterText">{heaterOn ? `${streakTeam === 'shields' ? 'Shields' : 'Swords'} are on a ${streakCount}-point heater` : 'No heater active'}</div>
    </div>
  );
}

export default function Home() {
  const [activeTab, setActiveTab] = useState('results');
  const [adminMode, setAdminMode] = useState(true);
  const [teamScore, setTeamScore] = useState({ shields: 6, swords: 5 });
  const [streakTeam, setStreakTeam] = useState('shields');
  const [streakCount, setStreakCount] = useState(3);
  const [matches, setMatches] = useState(initialMatches);
  const [handicaps, setHandicaps] = useState(initialHandicaps);

  const matchesByDay = useMemo(() => matches.reduce((acc, m) => {
    if (!acc[m.day]) acc[m.day] = [];
    acc[m.day].push(m);
    return acc;
  }, {}), [matches]);

  const totalScored = teamScore.shields + teamScore.swords;
  const remaining = Math.max(0, 17 - totalScored);
  const leader = teamScore.shields === teamScore.swords ? 'All Square' : teamScore.shields > teamScore.swords ? 'Shields lead' : 'Swords lead';

  const updateMatch = (id, field, value) => setMatches((prev) => prev.map((m) => m.id === id ? { ...m, [field]: value } : m));
  const updateHandicap = (section, name, value) => setHandicaps((prev) => ({
    ...prev,
    [section]: prev[section].map((row) => row.name === name ? { ...row, value } : row),
  }));

  return (
    <div className="page">
      <div className="container">
        <header className="hero">
          <img src="/logo-header.png" alt="The Golf Trip logo" className="heroLogo" />
          <h1>THE GOLF TRIP APP</h1>
          <div className="heroSub">Shields v Swords</div>
          <img src="/logo-badge.png" alt="Trip badge" className="badgeLogo" />
          <div className="pillRow">
            <Pill>May 20–23, 2026</Pill>
            <Pill>Frisco + SBCC</Pill>
            <Pill>Trip HQ</Pill>
          </div>
          <div className="modeRow">
            <Pill>{adminMode ? 'Admin Edit Mode' : 'View Only Mode'}</Pill>
            <button className="ghostBtn" onClick={() => setAdminMode((v) => !v)}>{adminMode ? 'Switch to View Only' : 'Switch to Admin Edit'}</button>
          </div>
        </header>

        <section className="topGrid">
          <div className="card">
            <div className="cardTitle">Overall Team Scoring</div>
            <div className="grid2">
              <ScoreControl label="Shields" value={teamScore.shields} setValue={(v) => setTeamScore((s) => ({ ...s, shields: v }))} adminMode={adminMode} />
              <ScoreControl label="Swords" value={teamScore.swords} setValue={(v) => setTeamScore((s) => ({ ...s, swords: v }))} adminMode={adminMode} />
            </div>
            <HeatMeter shields={teamScore.shields} swords={teamScore.swords} streakTeam={streakTeam} streakCount={streakCount} />
            <div className="grid3 statGrid">
              <div><div className="muted small">Status</div><div className="strong">{leader}</div></div>
              <div><div className="muted small">Points scored</div><div className="strong">{totalScored}</div></div>
              <div><div className="muted small">Points left</div><div className="strong">{remaining}</div></div>
            </div>
            <div className="grid2">
              <div>
                <div className="subTitle">Heater team</div>
                <div className="stackRow">
                  <button className={`chipBtn ${streakTeam === 'shields' ? 'chipActive' : ''}`} onClick={() => setStreakTeam('shields')} disabled={!adminMode}>Shields</button>
                  <button className={`chipBtn ${streakTeam === 'swords' ? 'chipActive' : ''}`} onClick={() => setStreakTeam('swords')} disabled={!adminMode}>Swords</button>
                </div>
              </div>
              <div>
                <div className="subTitle">Heater streak</div>
                <div className="scoreRow left">
                  {adminMode ? <button className="circleBtn" onClick={() => setStreakCount((s) => Math.max(0, s - 1))}>−</button> : null}
                  <div className="scoreValue smallVal">{streakCount}</div>
                  {adminMode ? <button className="circleBtn primary" onClick={() => setStreakCount((s) => s + 1)}>+</button> : null}
                </div>
              </div>
            </div>
          </div>

          <div className="sideStack">
            <div className="card">
              <div className="cardTitle">Teams</div>
              <div className="teamBlock"><div className="strong">Shields</div><div className="tagRow">{['Allan','Rahim','Silva','Travis'].map((p) => <span key={p} className="tag">{p}</span>)}</div></div>
              <div className="teamBlock"><div className="strong">Swords</div><div className="tagRow">{['Geraud','Luke','Sean','Marco'].map((p) => <span key={p} className="tag">{p}</span>)}</div></div>
            </div>
            <div className="card">
              <div className="cardTitle">Quick Notes</div>
              <div className="note">Thursday transport: Rahim will pick up some people; others may Uber from Westin.</div>
              <div className="note">Closest to the pin each morning on the shortest par 3. Must be on the green.</div>
              <div className="note">Enter final Gross, Net, and Team Points for each matchup. No hole-by-hole scoring needed.</div>
            </div>
          </div>
        </section>

        <div className="tabs">
          {['results', 'schedule', 'rules', 'handicaps'].map((tab) => (
            <button key={tab} className={`tabBtn ${activeTab === tab ? 'tabActive' : ''}`} onClick={() => setActiveTab(tab)}>{tab[0].toUpperCase() + tab.slice(1)}</button>
          ))}
        </div>

        {activeTab === 'results' && (
          <div className="stack4">
            {Object.entries(matchesByDay).map(([day, dayMatches]) => (
              <div className="card" key={day}>
                <div className="cardTitle">{day} Results</div>
                <div className="muted">Set the matchup, then enter Final Gross, Final Net, and Team Points.</div>
                <div className="stack4 topPad">
                  {dayMatches.map((match) => <MatchCard key={match.id} match={match} adminMode={adminMode} updateMatch={updateMatch} />)}
                </div>
              </div>
            ))}
          </div>
        )}

        {activeTab === 'schedule' && (
          <div className="gridSchedule">
            {schedule.map((day) => (
              <div className="card" key={day.day}>
                <div className="cardTitle">{day.title}</div>
                <div className="muted">{day.day}</div>
                <div className="stack3 topPad">
                  {day.items.map((item) => (
                    <div className="subCard" key={`${day.day}-${item.time}-${item.title}`}>
                      <div className="subTitle">{item.time}</div>
                      <div className="strong">{item.title}</div>
                      <div className="muted">{item.detail}</div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}

        {activeTab === 'rules' && (
          <div className="card">
            <div className="cardTitle">Rules Center</div>
            <div className="muted">Organized by format so nobody has to dig through the PDF on the course.</div>
            <div className="stack3 topPad">
              {rules.map((section) => (
                <details key={section.title} className="ruleItem">
                  <summary>{section.title}</summary>
                  <div className="stack2 topPad">
                    {section.bullets.map((b) => <div key={b} className="note">{b}</div>)}
                  </div>
                </details>
              ))}
            </div>
          </div>
        )}

        {activeTab === 'handicaps' && (
          <div className="gridSchedule">
            {Object.entries(handicaps).map(([section, rows]) => (
              <div className="card" key={section}>
                <div className="cardTitle">{section}</div>
                <div className="stack3 topPad">
                  {rows.map((row) => (
                    <div className="handicapRow" key={`${section}-${row.name}`}>
                      <div className="strong">{row.name}</div>
                      <div className="handicapValue">
                        {adminMode ? (
                          <input className="field" value={row.value} onChange={(e) => updateHandicap(section, row.name, e.target.value)} />
                        ) : (
                          <div className="readonly center">{row.value || '—'}</div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}

        <footer className="footerCard">
          <div>
            <div className="strong">This is the ideal version for the trip</div>
            <div className="muted">One clean link for schedules, rules, results, handicaps, and team scoring.</div>
          </div>
          <div className="tagRow">
            <span className="tag">Mobile-first</span>
            <span className="tag">Scoreboard-first</span>
            <span className="tag">Admin editable</span>
          </div>
        </footer>
      </div>
    </div>
  );
}
